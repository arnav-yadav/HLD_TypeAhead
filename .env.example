# Copy to .env and adjust as needed. Every tunable knob lives here.

# --- Postgres (durable source of truth for query->count) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=typeahead
PGUSER=postgres
PGPASSWORD=postgres

# --- Redis nodes (3 real instances for consistent hashing) ---
REDIS_NODES=localhost:6379,localhost:6380,localhost:6381
TRENDING_NODE_INDEX=0          # a single ZSET key cannot be sharded; it lives on ONE node

# --- Suggestion cache ---
SUGGEST_TTL_SECONDS=600        # 5-10 min range; top-k orderings are stable, so favor hit rate
RING_VIRTUAL_NODES=150         # virtual nodes per physical node (smooths distribution)

# --- Trending decay ---
TRENDING_TAU_SECONDS=720       # ~12 min; activity from ~tau*ln2 ago counts half as much as now
TRENDING_TOP_N=10
TRENDING_SEED_BASELINE=300     # top historical term normalized to ~this score on the live scale

# --- Batch writes ---
FLUSH_INTERVAL_MS=5000         # time-based flush
FLUSH_MAX_ENTRIES=100          # size-based flush (distinct queries buffered)

# --- Server ---
PORT=4000
